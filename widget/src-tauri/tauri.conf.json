{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "aiventbus-widget",
  "version": "0.1.0",
  "identifier": "com.aiventbus.widget",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "aiventbus",
        "width": 420,
        "height": 620,
        "resizable": true,
        "decorations": true,
        "alwaysOnTop": false,
        "transparent": false,
        "minWidth": 320,
        "minHeight": 400,
        "maxWidth": 700
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "aiventbus"
    }
  }
}
